# ============================================================
#  SwachhTech – Environment Configuration Template
#  Copy this file to .env and fill in your actual values.
# ============================================================

# ── PostgreSQL Database ──────────────────────────────────────
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=waste_management
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://your_db_user:your_db_password@db:5432/waste_management

# ── MQTT Broker ──────────────────────────────────────────────
# Public broker (no auth): broker.hivemq.com, port 1883
# Private HiveMQ Cloud:    <cluster>.hivemq.cloud, port 8883
MQTT_BROKER=broker.hivemq.com
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
